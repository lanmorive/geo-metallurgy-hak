NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Anthropic API ---
# LLM_BASE_URL=https://api.anthropic.com/v1/
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5

# --- Локальная vLLM ---
# LLM_BASE_URL=http://vllm:8000/v1
# LLM_API_KEY=local
# LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
# LLM_GUIDED_JSON=true
# LLM_MAX_CONCURRENCY=16

# --- Ollama ---
# LLM_BASE_URL=http://ollama:11434/v1
# LLM_MODEL=qwen2.5:14b
# LLM_MAX_CONCURRENCY=2

LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com/v1/
LLM_MODEL=claude-haiku-4-5
LLM_GUIDED_JSON=false
LLM_TIMEOUT=120
LLM_MAX_CONCURRENCY=8

EMBEDDING_MODEL=BAAI/bge-m3
BACKEND_CORS_ORIGINS=http://localhost:5173
# Backend в docker слушает host:8001 (vLLM — host:8000)
VITE_API_URL=http://localhost:8001
VITE_USE_MOCKS=0

# S3 (Yandex Object Storage). Пустые S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = локальный режим без S3.
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=nauchny-klubok-data
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
